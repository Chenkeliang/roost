{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Roost",
  "version": "0.2.0",
  "identifier": "dev.roost.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @roost/web build",
    "beforeDevCommand": "pnpm --filter @roost/web dev"
  },
  "app": {
    "windows": [
      {
        "title": "Roost",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:4317; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null,
      "dmg": {
        "background": null,
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "externalBin": [
      "binaries/roost-server"
    ]
  }
}
