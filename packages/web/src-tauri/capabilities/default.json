{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Roost desktop capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:allow-open-url",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "roost-server",
          "sidecar": true,
          "args": ["serve", "--port", "4317"]
        }
      ]
    }
  ]
}
