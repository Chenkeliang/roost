{
  "name": "roost",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:web": "pnpm --filter @roost/web test",
    "test:all": "pnpm test && pnpm --filter @roost/web test",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.1.0"
  }
}
